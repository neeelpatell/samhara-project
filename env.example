# MongoDB
MONGO_URL=mongodb://localhost:27017
# MONGODB_URI=  # alternative to MONGO_URL

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# AWS SES (same keys as next-boilerplate)
GENERAL_AWS_ACCESS_KEY_ID=
GENERAL_AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
GENERAL_AWS_AWS_REGION=ap-south-1

# Verified SES sender (must be verified in AWS SES)
SES_FROM_EMAIL=help@prepseed.com

# Where form submissions are emailed (comma-separated); vanshita@prepseed.com is always included
SAMHARA_NOTIFICATION_EMAIL=info@samhara.in

# Shows "Test payment – ₹1" in the package dropdown (Razorpay minimum is ₹1)
# SAMHARA_ENABLE_TEST_PACKAGE=true
# NEXT_PUBLIC_SAMHARA_ENABLE_TEST_PACKAGE=true
# Optional: force all packages to this INR instead of listed price (min 1)
# SAMHARA_TEST_PAYMENT_INR=1
# NEXT_PUBLIC_SAMHARA_TEST_PAYMENT_INR=1
